<script>
    // FUNGSI AUTO-SLIDE REVIEW nextbet188 (Makin Smooth & Bisa Di-klik)
    (() => {
        const slider = document.getElementById("KokoSlider");
        const track = slider?.querySelector(".penilaian-mwt-track");
        const cards = track ? Array.from(track.children) : [];
        const dotsWrap = slider?.querySelector(".penilaian-mwt-dots");

        if (!slider || !track || cards.length === 0) return;

        let index = 0, perView = 1, timer = null;

        const calcPerView = () => window.innerWidth >= 980 ? 3 : (window.innerWidth >= 720 ? 2 : 1);

        const buildDots = () => {
            if (!dotsWrap) return;
            dotsWrap.innerHTML = "";
            const pages = Math.ceil(cards.length / perView);
            
            // Bikin dots pake gaya modern sekalian ngasih fungsi klik
            dotsWrap.append(...Array.from({ length: pages }, (_, i) => {
                const d = document.createElement("span");
                d.className = `penilaian-mwt-dot ${i === 0 ? "is-active" : ""}`;
                d.style.cursor = "pointer"; // Biar keliatan bisa di-klik
                d.addEventListener('click', () => { slideTo(i); start(); });
                return d;
            }));
        };

        const setActiveDot = (page) => {
            if (!dotsWrap) return;
            Array.from(dotsWrap.children).forEach((d, i) => d.classList.toggle("is-active", i === page));
        };

        const slideTo = (page) => {
            const cardWidth = cards[0].getBoundingClientRect().width;
            const gap = parseFloat(getComputedStyle(track).gap) || 0;
            const step = (cardWidth + gap) * perView;
            
            const maxPage = Math.max(0, Math.ceil(cards.length / perView) - 1);
            index = page > maxPage ? 0 : page;

            // Tambahan efek geser smooth anti patah-patah ngab!
            track.style.transition = "transform 0.5s cubic-bezier(0.25, 1, 0.5, 1)";
            track.style.transform = `translateX(-${step * index}px)`;
            setActiveDot(index);
        };

        const start = () => { stop(); timer = setInterval(() => slideTo(index + 1), 3200); };
        const stop = () => { if (timer) clearInterval(timer); timer = null; };

        const refresh = () => {
            perView = calcPerView();
            buildDots();
            // Reset transition biar pas resize gak aneh
            track.style.transition = "none"; 
            slideTo(0);
            start();
        };

        // Kalo disentuh/di-hover, gesernya berenti biar member enak bacanya
        ['mouseenter', 'touchstart'].forEach(e => slider.addEventListener(e, stop, { passive: true }));
        ['mouseleave', 'touchend'].forEach(e => slider.addEventListener(e, start, { passive: true }));

        window.addEventListener("resize", () => {
            clearTimeout(window.__KokoResizeT);
            window.__KokoResizeT = setTimeout(refresh, 150); // Debounce biar gak berat
        });

        refresh();
    })();
</script>

<script>
    // FUNGSI SCROLL DETECT (Upgrade ke murni Vanilla JS biar 100% Anti Ngelag)
    document.addEventListener('DOMContentLoaded', () => {
        let scrollTimer; 

        // Pake passive: true biar scroll hape makin gacor lancarnya
        window.addEventListener('scroll', () => {
            if (scrollTimer) clearTimeout(scrollTimer);

            scrollTimer = setTimeout(() => {
                const targetElement = document.querySelector('.product-recommendations1');
                if (!targetElement) return;

                const rect = targetElement.getBoundingClientRect();
                
                // Cek kalo elemen udah masuk ke layar bawah
                if (rect.bottom <= window.innerHeight) {
                    
                    // Hitung jumlah checked ngab
                    const checkLength = document.querySelectorAll("input[name='frequent-products-pdp']:checked").length;
                    const checkedProductsEl = document.getElementById('checked-products');
                    if(checkedProductsEl) checkedProductsEl.textContent = checkLength;

                    // Samain tinggi kotak otomatis
                    const priceContainers = document.querySelectorAll('.price_container_cal');
                    if (priceContainers.length === 0) return;

                    let maxHeight = 0;
                    let minHeight = Infinity;
                    
                    priceContainers.forEach(el => {
                        el.style.height = 'auto'; // Reset dulu biar ngukurnya bener
                        const h = el.offsetHeight;
                        if (h > maxHeight) maxHeight = h;
                        if (h < minHeight) minHeight = h;
                    });

                    const isMobile = window.matchMedia('only screen and (max-width: 1023px)').matches;
                    
                    if (!isMobile && maxHeight >= minHeight) {
                        priceContainers.forEach(el => {
                            el.style.display = 'flex';
                            el.style.flexFlow = 'column';
                            el.style.justifyContent = 'flex-end';
                            el.style.height = `${maxHeight}px`;
                        });
                    }
                }
            }, 100); // Waktu nunggu dibikin 100ms aja biar makin sat-set
        }, { passive: true }); 
    });
</script>
