	<style>
    .SLOT {
        margin: 0;
        padding: 0;
        font-family: 'Playfair Display', 'Segoe UI', serif;
        background-color: transparent;
        color: #2ecc9f; /* Warna baru */
        overflow: hidden;
    }

    .popup-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .popup-container {
        position: relative;
        width: 90%;
        max-width: 420px;
        /* Gradasi Hijau Gelap ke Hitam */
        background: linear-gradient(145deg, rgba(6, 96, 67, 0.95), rgba(5, 2, 0, 0.95));
        border-radius: 20px;
        overflow: hidden;
        text-align: center;
        animation: rotateScaleIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275), greenPulse 3.5s infinite ease-in-out;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(6, 96, 67, 0.5);
        padding-bottom: 20px;
        border: 1px solid rgba(6, 96, 67, 0.4);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    /* 💚 Hijau berdenyut yang mewah */
    @keyframes greenPulse {
        0%, 100% {
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.7), 0 0 20px rgba(46, 204, 159, 0.2), 0 0 0 1px rgba(6, 96, 67, 0.5);
        }
        50% {
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.7), 0 0 30px rgba(46, 204, 159, 0.4), 0 0 0 1px rgba(46, 204, 159, 0.5);
        }
    }

    /* ✨ Shiny diagonal hijau cerah yang elegan */
    .popup-container::before {
        content: "";
        position: absolute;
        top: -100%;
        left: -100%;
        width: 200%;
        height: 200%;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0) 45%,
            rgba(46, 204, 159, 0.15) 50%,
            rgba(255, 255, 255, 0) 55%
        );
        animation: shineDiagonal 5s linear infinite;
        z-index: 2;
        pointer-events: none;
    }

    @keyframes shineDiagonal {
        0% { transform: translate(-100%, -100%) rotate(30deg); }
        100% { transform: translate(100%, 100%) rotate(30deg); }
    }

    .popup-image {
        width: 100%;
        display: block;
        border-bottom: 1px solid rgba(6, 96, 67, 0.5);
    }

    /* Area Tombol */
    .clk-btn-sgp {
        width: 97%;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        font-family: 'Poppins', sans-serif;
        font-weight: 700;
        padding: 20px;
        position: relative;
        overflow: hidden;
        margin: 0 auto;
    }

    /* Green Accent Line */
    .clk-btn-sgp::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: calc(100% - 30px);
        height: 2px;
        background: linear-gradient(90deg, transparent, #000000, #2ecc9f, #000000, transparent);
        opacity: 0.5;
        filter: blur(1px);
    }

    .clk-btn-sgp a {
        --blade-cut: 12px;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 16px 12px;
        margin: 0;
        border-radius: 14px;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 2px solid transparent;
        box-shadow: 0 8px 0px #000000;
        clip-path: polygon(var(--blade-cut) 0%, 100% 0%, 100% calc(100% - var(--blade-cut)), calc(100% - var(--blade-cut)) 100%, 0% 100%, 0% var(--blade-cut));
        z-index: 1;
        text-decoration: none;
    }

    /* Green Border Effect saat hover */
    .clk-btn-sgp a::after {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        background: linear-gradient(45deg, #2ecc9f, #000000, #066043, #000000, #2ecc9f);
        border-radius: 16px;
        z-index: -1;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .clk-btn-sgp a:hover::after { opacity: 1; }
    .clk-btn-sgp a:hover {
        transform: translateY(-6px) scale(1.03);
        border-color: #2ecc9f;
    }

    /* LOGIN BUTTON - Transparan ke Hijau Tua */
    .login {
        color: #2ecc9f !important;
        background: rgba(0, 0, 0, 0.5);
        border: 2px solid #066043;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    }

    .login::before {
        content: '▶';
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 14px;
        opacity: 0.7;
        transition: all 0.3s ease;
        filter: drop-shadow(0 0 3px #2ecc9f);
    }

    .login:hover {
        background: #04422e; /* Warna dasar hijau lebih gelap dari #066043 */
        box-shadow: 0 12px 0px #000000, 0 20px 40px rgba(46, 204, 159, 0.4), 0 0 30px rgba(46, 204, 159, 0.2);
        color: #ffffff !important;
        border-color: #2ecc9f;
    }

    .login:hover::before {
        opacity: 1;
        transform: translateY(-50%) rotate(15deg);
        filter: drop-shadow(0 0 8px #2ecc9f);
        color: #ffffff;
    }

    /* REGISTER BUTTON - Gradasi Hijau Gelap ke Hijau Terang */
    .register {
        color: #ffffff !important;
        background: linear-gradient(145deg, #066043, #2ecc9f);
        border: 2px solid transparent;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
    }

    .register::before {
        content: '★';
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 16px;
        opacity: 0.8;
        transition: all 0.3s ease;
    }

    .register:hover {
        background: linear-gradient(145deg, #2ecc9f, #066043);
        box-shadow: 0 12px 0px #000000, 0 20px 40px rgba(46, 204, 159, 0.5), 0 0 35px rgba(46, 204, 159, 0.3);
    }

    .register:hover::before {
        opacity: 1;
        transform: translateY(-50%) scale(1.2) rotate(360deg);
    }

    .clk-btn-sgp a span {
        display: inline-block;
        transition: transform 0.3s ease;
    }

    .clk-btn-sgp a:hover span { transform: translateX(3px); }

    /* Footer Text Popup */
    .popup-footer {
        font-size: 13px;
        color: #9cc7b8; /* Sedikit sentuhan warna kehijauan */
        padding: 10px 15px 20px;
        position: relative;
        z-index: 3;
        line-height: 1.6;
        font-family: 'Playfair Display', serif;
    }

    /* Animasi Masuk */
    @keyframes rotateScaleIn {
        0% { opacity: 0; transform: scale(0.3) rotate(-10deg); }
        50% { transform: scale(1.05) rotate(2deg); }
        100% { opacity: 1; transform: scale(1) rotate(0deg); }
    }

    /* Efek partikel hijau */
    .gold-particle {
        position: absolute;
        background: radial-gradient(circle, rgba(168, 240, 219, 0.8) 0%, rgba(46, 204, 159, 0.4) 100%);
        border-radius: 50%;
        pointer-events: none;
        z-index: 1;
        animation: floatGold 10s infinite ease-in-out;
        box-shadow: 0 0 10px rgba(46, 204, 159, 0.6);
    }

    @keyframes floatGold {
        0%, 100% { transform: translateY(0) translateX(0); opacity: 0; }
        10% { opacity: 0.8; }
        90% { opacity: 0.8; }
        100% { transform: translateY(-120px) translateX(40px); opacity: 0; }
    }

    /* Efek border mewah */
    .luxury-border {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border: 1px solid rgba(6, 96, 67, 0.4);
        border-radius: 20px;
        pointer-events: none;
        z-index: 4;
        background: linear-gradient(135deg, rgba(46, 204, 159, 0) 0%, rgba(46, 204, 159, 0.1) 50%, rgba(46, 204, 159, 0) 100%);
    }

    /* Tombol Close */
    .close-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        width: 32px;
        height: 32px;
        background: rgba(0, 0, 0, 0.5);
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        z-index: 10;
        transition: all 0.3s ease;
        border: 1px solid rgba(6, 96, 67, 0.5);
    }

    .close-btn:hover {
        background: rgba(46, 204, 159, 0.8);
        transform: rotate(90deg);
        border-color: #2ecc9f;
    }

    .close-btn::before, .close-btn::after {
        content: '';
        position: absolute;
        width: 16px;
        height: 2px;
        background: #2ecc9f;
        transition: background 0.3s ease;
    }

    .close-btn:hover::before, .close-btn:hover::after {
        background: #ffffff;
    }

    .close-btn::before { transform: rotate(45deg); }
    .close-btn::after { transform: rotate(-45deg); }

    /* Responsif Mobile */
    @media (max-width: 768px) {
        .clk-btn-sgp {
            grid-template-columns: 1fr;
            gap: 12px;
